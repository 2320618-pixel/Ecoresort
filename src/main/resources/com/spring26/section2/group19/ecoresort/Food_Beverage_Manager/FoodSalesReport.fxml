<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Food_Beverage_Manager.FoodSalesReportController">

    <children>

        <Label layoutX="230" layoutY="20" text="Daily Food Sales Report" style="-fx-font-size: 20px;" />

        <!-- Date -->
        <Label layoutX="50" layoutY="80" text="Select Date:" />
        <DatePicker fx:id="datePicker" layoutX="200" layoutY="75"/>

        <Button layoutX="350" layoutY="75" text="Generate Report" onAction="#handleGenerate"/>
        <Button layoutX="500" layoutY="75" text="Save Report" onAction="#handleSave"/>

        <!-- Summary -->
        <Label layoutX="50" layoutY="130" text="Sales Summary:" />
        <TextArea fx:id="summaryArea" layoutX="200" layoutY="130" prefWidth="500" prefHeight="120"/>

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="280" prefWidth="700" prefHeight="250">

            <columns>
                <TableColumn fx:id="colItem" text="Item" prefWidth="200"/>
                <TableColumn fx:id="colQty" text="Quantity Sold" prefWidth="200"/>
                <TableColumn fx:id="colTotal" text="Total Sales" prefWidth="200"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>