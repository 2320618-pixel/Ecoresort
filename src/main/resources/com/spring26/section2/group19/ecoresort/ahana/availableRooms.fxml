      <TextField fx:id="totalGuestField" layoutX="14.0" layoutY="98.0" promptText="total guest" />
      <TableView layoutX="14.0" layoutY="160.0" prefHeight="178.0" prefWidth="359.0">
        <columns>
          <TableColumn fx:id="roomNoCol" prefWidth="75.0" text="room no" />
          <TableColumn fx:id="typeCol" prefWidth="75.0" text="type" />
            <TableColumn fx:id="capacityCol" prefWidth="75.0" text="capacity " />
            <TableColumn fx:id="priceCol" prefWidth="75.0" text="price" />
        </columns>
      </TableView>
      <Button layoutX="114.0" layoutY="361.0" mnemonicParsing="false" onAction="#search" text="search" />
      <Button layoutX="507.0" layoutY="11.0" mnemonicParsing="false" onAction="#backButton" text="back" />
   </children>
</AnchorPane>
