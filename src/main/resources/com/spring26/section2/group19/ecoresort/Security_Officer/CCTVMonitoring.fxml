<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Security_Officer.CCTVMonitoringController">

    <children>

        <Label layoutX="260" layoutY="20" text="CCTV Monitoring System" style="-fx-font-size: 20px;" />

        <!-- Camera Selection -->
        <Label layoutX="50" layoutY="80" text="Select Camera:" />
        <ComboBox fx:id="cameraCombo" layoutX="200" layoutY="75" prefWidth="200"/>

        <Button layoutX="420" layoutY="75" text="View Camera" onAction="#handleViewCamera"/>

        <!-- Status -->
        <Label layoutX="50" layoutY="130" text="Status:" />
        <Label fx:id="statusLabel" layoutX="200" layoutY="130" text="---"/>

        <!-- Live Feed Placeholder -->
        <Label layoutX="50" layoutY="180" text="Live Feed:" />
        <TextArea fx:id="feedArea" layoutX="200" layoutY="180" prefWidth="300" prefHeight="120" editable="false"/>

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="330" prefWidth="700" prefHeight="200">

            <columns>
                <TableColumn fx:id="colId" text="Camera ID" prefWidth="150"/>
                <TableColumn fx:id="colLocation" text="Location" prefWidth="250"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="200"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>