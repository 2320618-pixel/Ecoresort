<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="604.0" prefWidth="830.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.ahana.mealsOrActivitiesController">
   <children>
      <TextField fx:id="totalField" layoutX="23.0" layoutY="244.0" promptText="total" />
      <TableView layoutX="23.0" layoutY="25.0" prefHeight="196.0" prefWidth="315.0">
        <columns>
          <TableColumn fx:id="roomCol" prefWidth="75.0" text="room" />
          <TableColumn fx:id="datesCol" prefWidth="75.0" text="dates" />
            <TableColumn fx:id="currentTotalCol" prefWidth="75.0" text="current total" />
        </columns>
      </TableView>
      <Button layoutX="23.0" layoutY="277.0" mnemonicParsing="false" onAction="#addservice" text="add service" />
      <ComboBox fx:id="service" layoutX="353.0" layoutY="38.0" prefWidth="150.0" promptText="service" />
      <ComboBox fx:id="activity" layoutX="358.0" layoutY="73.0" prefWidth="150.0" promptText="activity" />
      <Button layoutX="379.0" layoutY="111.0" mnemonicParsing="false" onAction="#add" text="add" />
      <TextField fx:id="updatedTotalField" layoutX="365.0" layoutY="148.0" promptText="updated total" />
      <Button layoutX="521.0" layoutY="13.0" mnemonicParsing="false" onAction="#backButton" text="back" />
      <PieChart fx:id="pieChart" layoutX="440.0" layoutY="269.0" prefHeight="294.0" prefWidth="288.0" />
   </children>
</AnchorPane>
