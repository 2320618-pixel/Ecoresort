<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Security_Officer.VisitorEntryLogController">

    <children>

        <Label layoutX="250" layoutY="20" text="Visitor Entry Log" style="-fx-font-size: 20px;" />

        <Label layoutX="50" layoutY="80" text="Visitor Name:" />
        <TextField fx:id="nameField" layoutX="200" layoutY="75" prefWidth="200"/>

        <Label layoutX="50" layoutY="130" text="Phone Number:" />
        <TextField fx:id="phoneField" layoutX="200" layoutY="125" prefWidth="200"/>

        <Label layoutX="50" layoutY="180" text="Purpose:" />
        <TextArea fx:id="purposeArea" layoutX="200" layoutY="175" prefWidth="200" prefHeight="80"/>

        <Label layoutX="50" layoutY="280" text="Entry Time:" />
        <DatePicker fx:id="entryDate" layoutX="200" layoutY="275"/>

        <Button layoutX="200" layoutY="330" text="Add Entry" onAction="#handleAddEntry"/>
        <Button layoutX="320" layoutY="330" text="Clear" onAction="#handleClear"/>

        <TableView fx:id="tableView" layoutX="50" layoutY="380" prefWidth="700" prefHeight="180">
            <columns>
                <TableColumn fx:id="colId" text="Entry ID" prefWidth="100"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                <TableColumn fx:id="colPhone" text="Phone" prefWidth="150"/>
                <TableColumn fx:id="colPurpose" text="Purpose" prefWidth="150"/>
                <TableColumn fx:id="colTime" text="Entry Time" prefWidth="150"/>
            </columns>
        </TableView>

    </children>
</AnchorPane>