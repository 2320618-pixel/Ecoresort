<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group19.ecoresort.SamihaJahanSaaj.ResortManagement.AddnewservicesController"
            prefHeight="500.0" prefWidth="700.0"><![CDATA[


        <!-- Title -->
        <Label text="Add New Resort Service"
               layoutX="220" layoutY="20"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <!-- Service Name -->
        <Label text="Service Name:"
               layoutX="150" layoutY="100" />

        <TextField fx:id="serviceNameField"
                   layoutX="300" layoutY="95"
                   prefWidth="200"
                   promptText="Enter service name" />

        <!-- Service Price -->
        <Label text="Service Price:"
               layoutX="150" layoutY="150" />

        <TextField fx:id="servicePriceField"
                   layoutX="300" layoutY="145"
                   prefWidth="200"
                   promptText="Enter price" />

        <!-- Validation Message -->
        <Label fx:id="validationLabel"
               layoutX="300" layoutY="180"
               text=""
               style="-fx-text-fill: red;" />

        <!-- Buttons -->
        <Button text="Save Service"
                layoutX="300" layoutY="230"
                prefWidth="120"
                onAction="#handleSaveService" />

        <Button text="Clear"
                layoutX="440" layoutY="230"
                prefWidth="80"
                onAction="#handleClearForm" />

        <!-- Success Message -->
        <Label fx:id="successLabel"
               layoutX="300" layoutY="280"
               text=""
               style="-fx-text-fill: green; -fx-font-weight: bold;" /><![CDATA[


</AnchorPane>