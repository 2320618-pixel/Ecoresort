<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.walkInGuestsController">
   <children>
      <TextField fx:id="guestNameField" layoutX="23.0" layoutY="24.0" promptText="guest name" />
      <Button layoutX="23.0" layoutY="56.0" mnemonicParsing="false" onAction="#checkAvailability" text="check availability" />
      <TableView layoutX="34.0" layoutY="100.0" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="roomNoCol" prefWidth="75.0" text="room no" />
          <TableColumn fx:id="typeCol" prefWidth="75.0" text="type" />
            <TableColumn fx:id="billCol" prefWidth="75.0" text="bill" />
        </columns>
      </TableView>
      <ComboBox fx:id="selectRoom" layoutX="41.0" layoutY="311.0" prefWidth="150.0" promptText="select room" />
      <TextField fx:id="enterDepositAmountField" layoutX="42.0" layoutY="343.0" promptText="enter deposit amount" />
      <Button layoutX="242.0" layoutY="324.0" mnemonicParsing="false" onAction="#confirmBooking" text="confirm booking" />
   </children>
</AnchorPane>
