<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group19.ecoresort.SamihaJahanSaaj.ResortManagement.ManageRoomPricingController"
            prefHeight="400.0" prefWidth="600.0">
    <children>

        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <!-- 🔷 HEADER -->
            <top>
                <HBox spacing="10" style="-fx-background-color: #2C3E50; -fx-padding: 12;">
                    <Label text="Room Pricing Management"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Refresh"/>
                    <Button text="Save All"/>
                </HBox>
            </top>

            <!-- 🔷 CENTER CONTENT -->
            <center>
                <VBox spacing="15" style="-fx-padding: 20;">

                    <!-- Title -->
                    <Label text="Manage Room Prices"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                    <!-- 🔶 TABLE VIEW (Event 2 - OP) -->
                    <TableView fx:id="pricingTable" prefHeight="250">

                        <columns>
                            <TableColumn text="Room Type" prefWidth="150"/>
                            <TableColumn text="Current Price" prefWidth="120"/>
                            <TableColumn text="New Price" prefWidth="120"/>
                        </columns>

                    </TableView>

                    <!-- 🔶 UPDATE SECTION (Event 3 - UID) -->
                    <GridPane hgap="10" vgap="10">

                        <Label text="Room Type:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="roomTypeBox"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="New Price:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="priceField"
                                   promptText="Enter new price"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Button text="Update Price"
                                GridPane.rowIndex="2"
                                GridPane.columnIndex="1"/>
                    </GridPane>

                </VBox>
            </center>

            <!-- 🔷 RIGHT PANEL (INFO / STATUS) -->
            <right>
                <VBox spacing="10" prefWidth="200"
                      style="-fx-background-color: #ECF0F1; -fx-padding: 15;">

                    <Label text="Instructions"
                           style="-fx-font-weight: bold;" />

                    <Label text="• Select a room type"/>
                    <Label text="• Enter new price"/>
                    <Label text="• Click update"/>

                    <Separator/>

                    <Label text="Status"
                           style="-fx-font-weight: bold;" />

                    <Label fx:id="statusLabel" text="No changes yet"/>
                </VBox>
            </right>

            <!-- 🔷 FOOTER -->
            <bottom>
                <HBox style="-fx-background-color: #BDC3C7; -fx-padding: 10;">
                    <Label text="System ready"/>
                </HBox>
            </bottom>

        </BorderPane>

    </children>

</AnchorPane>
