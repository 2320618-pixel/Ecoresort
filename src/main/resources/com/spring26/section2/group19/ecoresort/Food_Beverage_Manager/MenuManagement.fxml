<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Food_Beverage_Manager.MenuManagementController">

    <children>

        <!-- Title -->
        <Label layoutX="250" layoutY="20" text="Menu Management" style="-fx-font-size: 20px;" />

        <!-- Item Name -->
        <Label layoutX="50" layoutY="80" text="Item Name:" />
        <TextField fx:id="nameField" layoutX="200" layoutY="75" prefWidth="200"/>

        <!-- Category -->
        <Label layoutX="50" layoutY="130" text="Category:" />
        <ComboBox fx:id="categoryCombo" layoutX="200" layoutY="125" prefWidth="200"/>

        <!-- Price -->
        <Label layoutX="50" layoutY="180" text="Price:" />
        <TextField fx:id="priceField" layoutX="200" layoutY="175" prefWidth="200"/>

        <!-- Availability -->
        <Label layoutX="50" layoutY="230" text="Availability:" />
        <RadioButton fx:id="availableBtn" layoutX="200" layoutY="230" text="Available"/>
        <RadioButton fx:id="notAvailableBtn" layoutX="320" layoutY="230" text="Not Available"/>

        <!-- Buttons -->
        <Button layoutX="200" layoutY="280" text="Add / Update" onAction="#handleSave"/>
        <Button layoutX="340" layoutY="280" text="Clear" onAction="#handleClear"/>
        <Button layoutX="480" layoutY="280" text="Save File" onAction="#save"/>

        <!-- Message Label -->
        <Label fx:id="msgLabel" layoutX="200" layoutY="320" style="-fx-text-fill: green;" />

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="350" prefWidth="700" prefHeight="220">

            <columns>
                <TableColumn fx:id="colName" text="Item Name" prefWidth="150"/>
                <TableColumn fx:id="colCategory" text="Category" prefWidth="150"/>
                <TableColumn fx:id="colPrice" text="Price" prefWidth="150"/>
                <TableColumn fx:id="colAvailability" text="Availability" prefWidth="200"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>