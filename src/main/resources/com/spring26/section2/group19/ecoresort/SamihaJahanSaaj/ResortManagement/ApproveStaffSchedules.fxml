<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group19.ecoresort.SamihaJahanSaaj.ResortManagement.ApproveStaffSchedulesController"
            prefHeight="400.0" prefWidth="600.0" >
    <children>

        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <!-- 🔷 HEADER -->
            <top>
                <HBox spacing="10" style="-fx-background-color: #2C3E50; -fx-padding: 12;">
                    <Label text="Staff Schedule Approval"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Refresh"/>
                </HBox>
            </top>

            <!-- 🔷 CENTER CONTENT -->
            <center>
                <VBox spacing="15" style="-fx-padding: 20;">

                    <!-- Title -->
                    <Label text="Weekly Staff Schedules"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                    <!-- 🔶 TABLE VIEW (Event 2 - OP) -->
                    <TableView fx:id="scheduleTable" prefHeight="300">

                        <columns>
                            <TableColumn text="Staff Name" prefWidth="120"/>
                            <TableColumn text="Role" prefWidth="100"/>
                            <TableColumn text="Day" prefWidth="100"/>
                            <TableColumn text="Shift" prefWidth="100"/>
                            <TableColumn text="Status" prefWidth="100"/>
                        </columns>

                    </TableView>

                    <!-- 🔶 ACTION PANEL (Event 3 - UID) -->
                    <HBox spacing="10">

                        <Button text="Approve Schedule"
                                fx:id="approveBtn"/>

                        <Button text="Edit Schedule"
                                fx:id="editBtn"/>

                        <Button text="Reject"
                                fx:id="rejectBtn"/>

                    </HBox>

                </VBox>
            </center>

            <!-- 🔷 RIGHT PANEL (DETAILS + STATUS) -->
            <right>
                <VBox spacing="12" prefWidth="220"
                      style="-fx-background-color: #ECF0F1; -fx-padding: 15;">

                    <Label text="Schedule Details"
                           style="-fx-font-weight: bold;" />

                    <Label text="Select a schedule to view details"
                           wrapText="true"/>

                    <Separator/>

                    <Label text="Update Status"
                           style="-fx-font-weight: bold;" />

                    <Label fx:id="statusLabel" text="No action yet"/>

                    <Separator/>

                    <Label text="Instructions"
                           style="-fx-font-weight: bold;" />

                    <Label text="• Select a schedule"/>
                    <Label text="• Click Approve or Edit"/>
                    <Label text="• Status will be updated"/>

                </VBox>
            </right>

            <!-- 🔷 FOOTER -->
            <bottom>
                <HBox style="-fx-background-color: #BDC3C7; -fx-padding: 10;">
                    <Label text="System ready"/>
                </HBox>
            </bottom>

        </BorderPane>

    </children>

</AnchorPane>
