<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.farzana.workAsCompletedController">
   <children>
      <Button layoutX="65.0" layoutY="43.0" mnemonicParsing="false" text="Mark as Completed" />
      <TableView fx:id="TourTable" layoutX="254.0" prefHeight="200.0" prefWidth="332.0">
        <columns>
          <TableColumn fx:id="validatesCompletionColumn" prefWidth="75.0" text="Validates Completion" />
          <TableColumn fx:id="ShowsConfirmationColumn" prefWidth="75.0" text="Shows Confirmation" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="466.0" layoutY="244.0" mnemonicParsing="false" onAction="#acceptButton" text="Accept" />
      <Button layoutX="486.0" layoutY="288.0" mnemonicParsing="false" onAction="#rejectButton" text="Reject" />
   </children>
</AnchorPane>
