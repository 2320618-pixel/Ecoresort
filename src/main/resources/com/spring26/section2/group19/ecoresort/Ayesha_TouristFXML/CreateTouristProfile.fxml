<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="514.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.Ayesha.CreateTouristProfileController">
   <children>
      <Label layoutX="182.0" layoutY="29.0" prefHeight="36.0" prefWidth="236.0" text="Create Tourist Profile">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <TextField fx:id="nametext" layoutX="136.0" layoutY="85.0" />
      <TextField fx:id="phonetext" layoutX="136.0" layoutY="128.0" />
      <TextField fx:id="emailText" layoutX="136.0" layoutY="176.0" />
      <Label layoutX="31.0" layoutY="89.0" prefHeight="18.0" prefWidth="87.0" text="Name:" />
      <Label layoutX="31.0" layoutY="132.0" prefHeight="18.0" prefWidth="80.0" text="Phone:" />
      <Label layoutX="31.0" layoutY="180.0" prefHeight="18.0" prefWidth="87.0" text="Email:" />
      <RadioButton layoutX="149.0" layoutY="235.0" mnemonicParsing="false" text="Male">
         <toggleGroup>
            <ToggleGroup fx:id="radio" />
         </toggleGroup></RadioButton>
      <RadioButton layoutX="224.0" layoutY="235.0" mnemonicParsing="false" text="Female" toggleGroup="$radio" />
      <Label layoutX="31.0" layoutY="277.0" prefHeight="18.0" prefWidth="87.0" text="Date Of Birth:" />
      <DatePicker fx:id="date" layoutX="119.0" layoutY="274.0" />
      <TextArea fx:id="preferancesTxtArea" layoutX="36.0" layoutY="328.0" prefHeight="51.0" prefWidth="495.0" promptText="preferances(food,room type etc)" />
      <Button layoutX="232.0" layoutY="416.0" mnemonicParsing="false" onAction="#saveBtn" prefHeight="26.0" prefWidth="143.0" text="SAVE" />
      <Label layoutX="31.0" layoutY="234.0" prefHeight="18.0" prefWidth="80.0" text="Gender:" />
   </children>
</AnchorPane>
