<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.mealsOrActivitiesController">
   <children>
      <TextField fx:id="totalField" layoutX="23.0" layoutY="244.0" promptText="total" />
      <TableView layoutX="23.0" layoutY="25.0" prefHeight="196.0" prefWidth="315.0">
        <columns>
          <TableColumn fx:id="roomCol" prefWidth="75.0" text="room" />
          <TableColumn fx:id="datesCol" prefWidth="75.0" text="dates" />
            <TableColumn fx:id="currentTotalCol" prefWidth="75.0" text="current total" />
        </columns>
      </TableView>
      <Button layoutX="23.0" layoutY="277.0" mnemonicParsing="false" onAction="#addservice" text="add service" />
      <ComboBox fx:id="service" layoutX="414.0" layoutY="35.0" prefWidth="150.0" promptText="service" />
      <ComboBox fx:id="activity" layoutX="414.0" layoutY="73.0" prefWidth="150.0" promptText="activity" />
      <Button layoutX="414.0" layoutY="113.0" mnemonicParsing="false" onAction="#add" text="add" />
      <TextField fx:id="updatedTotalField" layoutX="415.0" layoutY="145.0" promptText="updated total" />
   </children>
</AnchorPane>
