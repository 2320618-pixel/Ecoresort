<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Security_Officer.IncidentReportController">

    <children>

        <Label layoutX="250" layoutY="20" text="Security Incident Report" style="-fx-font-size: 20px;" />

        <!-- Incident Type -->
        <Label layoutX="50" layoutY="80" text="Incident Type:" />
        <ComboBox fx:id="typeCombo" layoutX="200" layoutY="75" prefWidth="200"/>

        <!-- Location -->
        <Label layoutX="50" layoutY="130" text="Location:" />
        <TextField fx:id="locationField" layoutX="200" layoutY="125" prefWidth="200"/>

        <!-- Description -->
        <Label layoutX="50" layoutY="180" text="Description:" />
        <TextArea fx:id="descriptionArea" layoutX="200" layoutY="175" prefWidth="200" prefHeight="80"/>

        <!-- Date -->
        <Label layoutX="50" layoutY="280" text="Incident Date:" />
        <DatePicker fx:id="datePicker" layoutX="200" layoutY="275"/>

        <!-- Buttons -->
        <Button layoutX="200" layoutY="330" text="Submit Report" onAction="#handleSubmit"/>
        <Button layoutX="340" layoutY="330" text="Clear" onAction="#handleClear"/>

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="380" prefWidth="700" prefHeight="180">

            <columns>
                <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                <TableColumn fx:id="colLocation" text="Location" prefWidth="150"/>
                <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>