          <TableColumn fx:id="systemSavesUpdateColumn" prefWidth="75.0" text="System Saves Update" />
          <TableColumn fx:id="tourUpdateColumn" prefWidth="75.0" text="Tour Update" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <TableView layoutY="200.0" prefHeight="200.0" prefWidth="395.0">
        <columns>
          <TableColumn fx:id="systemStatusColumn" prefWidth="75.0" text="system Status" />
            <TableColumn fx:id="systemStatusColumn1" prefWidth="75.0" text="system Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</AnchorPane>
