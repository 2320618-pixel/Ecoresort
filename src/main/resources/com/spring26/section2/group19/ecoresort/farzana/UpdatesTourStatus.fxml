<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.farzana.UpdatesTourStatusController">
   <children>
      <Button fx:id="updatesTourStatusTable" layoutX="14.0" layoutY="45.0" mnemonicParsing="false" text="Updates Tour Status" />
      <Button layoutX="516.0" layoutY="300.0" mnemonicParsing="false" onAction="#acceptButton" text="Accept" />
      <Button layoutX="516.0" layoutY="336.0" mnemonicParsing="false" onAction="#rejectButton" text="Reject" />
      <TableView layoutX="173.0" prefHeight="200.0" prefWidth="354.0">
