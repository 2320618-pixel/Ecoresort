<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.farzana.updateTourStatusController">
   <children>
      <Button layoutX="25.0" layoutY="24.0" mnemonicParsing="false" onAction="#updateTourStatusTabButton" text="Update Tour Status" />
      <TableView fx:id="tourTable" layoutX="177.0" prefHeight="200.0" prefWidth="364.0">
        <columns>
          <TableColumn prefWidth="75.0" text="Started/Cancelled" />
          <TableColumn prefWidth="75.0" text="Status input" />
            <TableColumn prefWidth="75.0" text="Update and shows confirmation" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="464.0" layoutY="239.0" mnemonicParsing="false" onAction="#acceptButton" text="Accept" />
      <Button fx:id="rejectButton" layoutX="464.0" layoutY="284.0" mnemonicParsing="false" onAction="#rejectButton" text="Reject" />
      <Button layoutX="207.0" layoutY="309.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
