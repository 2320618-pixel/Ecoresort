<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.farzana.recordGuestsController">
   <children>
      <Button layoutX="44.0" layoutY="31.0" mnemonicParsing="false" text="Record Guests" />
      <TableView layoutX="37.0" layoutY="200.0" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="loadGuestsListColumn" prefWidth="75.0" text="Load guests List" />
          <TableColumn fx:id="guideMarkAttendanceColumn" prefWidth="75.0" text="Guide Mark Attendance" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="310.0" layoutY="266.0" mnemonicParsing="false" onAction="#acceptButton" text="Accept" />
      <Button layoutX="460.0" layoutY="266.0" mnemonicParsing="false" onAction="#rejectButton" text="Reject" />
   </children>
</AnchorPane>
