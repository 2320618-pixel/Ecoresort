      </TableView>
      <TableView layoutX="27.0" layoutY="200.0" prefHeight="200.0" prefWidth="354.0">
        <columns>
          <TableColumn fx:id="ValidatesInputColumn" prefWidth="75.0" text="Enters Feedback" />
          <TableColumn prefWidth="75.0" text="Validates Input" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button layoutX="403.0" layoutY="234.0" mnemonicParsing="false" onAction="#acceptButton" text="Accept" />
      <Button layoutX="403.0" layoutY="288.0" mnemonicParsing="false" onAction="#rejectButton" text="Reject" />
   </children>
</AnchorPane>
