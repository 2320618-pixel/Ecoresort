<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.farzana.SubmitActivityFeedbackController">
   <children>
      <ComboBox fx:id="selectActivityComboBox" layoutX="39.0" layoutY="62.0" prefWidth="150.0" promptText="Select Activities" />
      <TextField fx:id="FeedbackField" layoutX="142.0" layoutY="114.0" text="EnterFeedback" />
      <Button layoutX="283.0" layoutY="188.0" mnemonicParsing="false" onAction="#submitButton" text="Submit" />
      <Button layoutX="100.0" layoutY="310.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
   </children>
</AnchorPane>
