<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Food_Beverage_Manager.SpecialDietaryRequestsController">

    <children>

        <Label layoutX="220" layoutY="20" text="Special Dietary Requests" style="-fx-font-size: 20px;" />

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="80" prefWidth="700" prefHeight="300">

            <columns>
                <TableColumn fx:id="colGuest" text="Guest Name" prefWidth="150"/>
                <TableColumn fx:id="colRoom" text="Room No" prefWidth="120"/>
                <TableColumn fx:id="colRequest" text="Request" prefWidth="250"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
            </columns>

        </TableView>

        <!-- Buttons -->
        <Button layoutX="250" layoutY="420" text="Approve" onAction="#handleApprove"/>
        <Button layoutX="370" layoutY="420" text="Reject" onAction="#handleReject"/>

    </children>
</AnchorPane>