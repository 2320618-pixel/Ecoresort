<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600" prefWidth="800"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.spring26.section2.group19.ecoresort.Food_Beverage_Manager.RestaurantOrdersController">

    <children>

        <Label layoutX="250" layoutY="20" text="Restaurant Orders" style="-fx-font-size: 20px;" />

        <!-- Order Input -->
        <Label layoutX="50" layoutY="80" text="Order ID:" />
        <TextField fx:id="idField" layoutX="200" layoutY="75"/>

        <Label layoutX="50" layoutY="120" text="Item:" />
        <TextField fx:id="itemField" layoutX="200" layoutY="115"/>

        <Label layoutX="50" layoutY="160" text="Quantity:" />
        <TextField fx:id="qtyField" layoutX="200" layoutY="155"/>

        <!-- Buttons -->
        <Button layoutX="200" layoutY="200" text="Add Order" onAction="#handleAdd"/>
        <Button layoutX="320" layoutY="200" text="Update Status" onAction="#handleUpdate"/>
        <Button layoutX="470" layoutY="200" text="Save File" onAction="#handleSaveFile"/>

        <!-- Status Selection -->
        <ComboBox fx:id="statusCombo" layoutX="200" layoutY="240" promptText="Select Status"/>

        <!-- Message -->
        <Label fx:id="msgLabel" layoutX="200" layoutY="280"/>

        <!-- Table -->
        <TableView fx:id="tableView" layoutX="50" layoutY="320" prefWidth="700" prefHeight="230">

            <columns>
                <TableColumn fx:id="colId" text="Order ID"/>
                <TableColumn fx:id="colItem" text="Item"/>
                <TableColumn fx:id="colQty" text="Quantity"/>
                <TableColumn fx:id="colStatus" text="Status"/>
            </columns>

        </TableView>

    </children>
</AnchorPane>