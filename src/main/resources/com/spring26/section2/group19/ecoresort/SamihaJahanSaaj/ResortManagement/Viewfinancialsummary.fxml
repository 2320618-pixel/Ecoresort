<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group19.ecoresort.SamihaJahanSaaj.ResortManagement.ViewfinancialsummuryController"
            prefHeight="500.0" prefWidth="700.0">

    <children>

        <Label text="Financial Summary"
               layoutX="250" layoutY="20"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <Label text="Income:" layoutX="100" layoutY="100"/>
        <Label fx:id="incomeLabel" layoutX="200" layoutY="100"/>

        <Label text="Expenses:" layoutX="100" layoutY="140"/>
        <Label fx:id="expenseLabel" layoutX="200" layoutY="140"/>

        <Label text="Profit:" layoutX="100" layoutY="180"/>
        <Label fx:id="profitLabel" layoutX="200" layoutY="180"/>

        <Button text="Load Data"
                layoutX="250" layoutY="250"
                onAction="#handleRefreshData"/>

    </children>
</AnchorPane>