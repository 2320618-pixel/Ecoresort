<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.ahana.checkGuestController">
   <children>
      <TextField fx:id="bookingIdeField" layoutX="14.0" layoutY="14.0" promptText="booking id" />
      <Button layoutX="14.0" layoutY="60.0" mnemonicParsing="false" onAction="#searchButton" text="search" />
      <TableView fx:id="guestTable" layoutX="14.0" layoutY="85.0" prefHeight="200.0" prefWidth="561.0">
        <columns>
          <TableColumn fx:id="guestDetailsCol" prefWidth="75.0" text="Guest details" />
          <TableColumn fx:id="roomNumberCol" prefWidth="75.0" text="Room number" />
        </columns>
      </TableView>
      <Button layoutX="21.0" layoutY="325.0" mnemonicParsing="false" onAction="#confirmedButton" text="confirmed guest identity" />
      <Button layoutX="300.0" layoutY="325.0" mnemonicParsing="false" onAction="#markRoomButton" text="Mark room as occupied" />
      <Button layoutX="508.0" layoutY="14.0" mnemonicParsing="false" onAction="#backButton" text="back" />
   </children>
</AnchorPane>
