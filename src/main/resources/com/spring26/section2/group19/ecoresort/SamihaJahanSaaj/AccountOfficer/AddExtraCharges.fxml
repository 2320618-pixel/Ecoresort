<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="420.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group19.ecoresort.SamihaJahanSaaj.AccountOfficer.AddExtraChargesController">

    <children>
        <Text layoutX="250.0" layoutY="35.0" text="Add Extra Charges">
            <font>
                <Font size="24.0" />
            </font>
        </Text>

        <Text layoutX="40.0" layoutY="80.0" text="Guest Billing Profile">
            <font>
                <Font size="16.0" />
            </font>
        </Text>

        <TableView fx:id="guestBillingTable" layoutX="40.0" layoutY="100.0" prefHeight="160.0" prefWidth="620.0">
            <columns>
                <TableColumn fx:id="guestIdColumn" prefWidth="150.0" text="Guest ID" />
                <TableColumn fx:id="guestNameColumn" prefWidth="220.0" text="Guest Name" />
                <TableColumn fx:id="balanceColumn" prefWidth="250.0" text="Current Balance" />
            </columns>
        </TableView>

        <Text layoutX="40.0" layoutY="300.0" text="Charge Type" />
        <TextField fx:id="chargeTypeTextField" layoutX="130.0" layoutY="285.0" prefWidth="180.0" />

        <Text layoutX="340.0" layoutY="300.0" text="Charge Amount" />
        <TextField fx:id="chargeAmountTextField" layoutX="450.0" layoutY="285.0" prefWidth="120.0" />

        <Button fx:id="addChargeButton" layoutX="590.0" layoutY="285.0" mnemonicParsing="false" onAction="#addChargeButton" text="Add Charge" />

        <Text layoutX="40.0" layoutY="350.0" text="Updated Balance" />
        <TextField fx:id="updatedBalanceTextField" editable="false" layoutX="150.0" layoutY="335.0" prefWidth="180.0" />

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="380.0" prefWidth="500.0" text="" />
      <Button layoutX="608.0" layoutY="376.0" mnemonicParsing="false" onAction="#backButton" text="Back" />
    </children>
</AnchorPane>
